<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KEBUGARAN JASMANI - Program Latihan & Diet</title>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }

        header {
            text-align: center;
            color: white;
            margin-bottom: 40px;
            padding: 20px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
        }

        h1 {
            font-size: 2.5em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .slider-container {
            position: relative;
            max-width: 100%;
            margin: 40px auto;
            overflow: hidden;
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.3);
        }

        .slider {
            display: flex;
            transition: transform 0.5s ease-in-out;
            height: 600px;
        }

        .slide {
            min-width: 100%;
            height: 600px;
            background: white;
            padding: 40px;
            box-sizing: border-box;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .slide h2 {
            font-size: 2.5em;
            color: #333;
            margin-bottom: 20px;
            background: linear-gradient(45deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .slide p {
            font-size: 1.2em;
            margin-bottom: 30px;
            max-width: 800px;
            line-height: 1.8;
        }

        .btn {
            background: linear-gradient(45deg, #667eea, #764ba2);
            color: white;
            padding: 15px 30px;
            border: none;
            border-radius: 50px;
            font-size: 1.1em;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0,0,0,0.2);
            margin: 10px;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px rgba(0,0,0,0.3);
        }

        .btn-secondary {
            background: linear-gradient(45deg, #ff6b6b, #ee5a24);
        }

        .btn-diet {
            background: linear-gradient(45deg, #00b894, #00a085);
        }

        .nav-buttons {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.9);
            border: none;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 1.5em;
            transition: all 0.3s ease;
            z-index: 10;
        }

        .prev { left: 20px; }
        .next { right: 20px; }

        .nav-buttons:hover {
            background: white;
            transform: translateY(-50%) scale(1.1);
        }

        .dots-container {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-top: 20px;
        }

        .dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: rgba(255,255,255,0.5);
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .dot.active {
            background: white;
            transform: scale(1.3);
        }

        /* Diet Features */
        .diet-features {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }

        .feature-card {
            background: rgba(255,255,255,0.9);
            padding: 25px;
            border-radius: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

        .feature-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .feature-icon {
            font-size: 3em;
            margin-bottom: 15px;
            background: linear-gradient(45deg, #667eea, #764ba2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        /* Bodybuilding Levels */
        .bb-levels {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }

        .level-card {
            background: linear-gradient(135deg, #667eea, #764ba2);
            color: white;
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 15px 30px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
        }

        .level-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
            transition: left 0.5s;
        }

        .level-card:hover::before {
            left: 100%;
        }

        .level-card:hover {
            transform: translateY(-15px) scale(1.05);
            box-shadow: 0 25px 50px rgba(0,0,0,0.3);
        }

        .level-icon {
            font-size: 4em;
            margin-bottom: 20px;
        }

        .level-title {
            font-size: 1.5em;
            margin-bottom: 15px;
            font-weight: bold;
        }

        /* Progress Tracker */
        .progress-tracker {
            background: rgba(255,255,255,0.95);
            padding: 30px;
            border-radius: 20px;
            margin-top: 20px;
        }

        .input-group {
            margin-bottom: 20px;
        }

        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-weight: bold;
            color: #333;
        }

        .input-group input {
            width: 100%;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 10px;
            font-size: 1em;
            transition: border-color 0.3s ease;
        }

        .input-group input:focus {
            outline: none;
            border-color: #667eea;
        }

        .chart-container {
            height: 300px;
            margin-top: 20px;
            background: #f8f9ff;
            border-radius: 15px;
            padding: 20px;
        }

        @media (max-width: 768px) {
            .slide {
                height: 500px;
                padding: 20px;
            }
            
            .slide h2 {
                font-size: 2em;
            }
            
            h1 {
                font-size: 2em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1><i class="fas fa-dumbbell"></i> KEBUGARAN JASMANI</h1>
            <p>Program Latihan Terlengkap untuk Semua Level Fitness</p>
        </header>

        <div class="slider-container">
            <div class="slider" id="slider">
                <!-- Slide 1: Program Umum -->
                <div class="slide active">
                    <h2><i class="fas fa-fire"></i> PROGRAM LATIHAN</h2>
                    <p>Pilih program latihan sesuai dengan tujuan dan level kebugaran Anda. Dari pemula hingga atlet profesional.</p>
                    <button class="btn" onclick="goToSlide(1)">Lihat Program</button>
                </div>

                <!-- Slide 2: PROGRAM FITNESS -->
                <div class="slide">
                    <h2><i class="fas fa-running"></i> FITNESS</h2>
                    <p>Program untuk meningkatkan daya tahan kardio, fleksibilitas, dan kebugaran umum. Cocok untuk semua usia.</p>
                    <div class="diet-features">
                        <div class="feature-card">
                            <div class="feature-icon"><i class="fas fa-chart-line"></i></div>
                            <h3>Progress Tracker</h3>
                            <p>Input berat badan mingguan & 1RM</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon"><i class="fas fa-book"></i></div>
                            <h3>Log Latihan</h3>
                            <p>Catat repetisi & set setiap sesi</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon"><i class="fas fa-utensils"></i></div>
                            <h3>Generator Menu</h3>
                            <p>Saran menu berdasarkan anggaran</p>
                        </div>
                        <div class="feature-card">
                            <div class="feature-icon"><i class="fas fa-clock"></i></div>
                            <h3>Timer Istirahat</h3>
                            <p>Hitung mundur 60-90 detik</p>
                        </div>
                    </div>
                </div>

                <!-- Slide 3: PROGRAM DIET (BARU) -->
                <div class="slide">
                    <h2><i class="fas fa-apple-alt"></i> PROGRAM DIET</h2>
                    <p>Optimalkan hasil latihan dengan nutrisi yang tepat. Pilih program diet sesuai kebutuhan tubuh Anda.</p>
                    <button class="btn btn-diet" onclick="showDietOptions()">Pilih Program Diet</button>
                    <div id="diet-options" style="display: none; margin-top: 30px;">
                        <button class="btn" onclick="goToSlide(4)">Bodybuilding</button>
                        <button class="btn btn-secondary" onclick="showProgressTracker()">Fat Loss</button>
                        <button class="btn" onclick="showCustomDiet()">Maintenance</button>
                    </div>
                </div>

                <!-- Slide 4: BODYBUILDING -->
                <div class="slide">
                    <h2><i class="fas fa-weight-hanging"></i> BODYBUILDING</h2>
                    <p>Pilih level bodybuilding sesuai pengalaman dan target Anda. Dari fondasi hingga hipertrofi maksimal.</p>
                    <div class="bb-levels">
                        <div class="level-card" onclick="showLevelDetail('medium')">
                            <div class="level-icon"><i class="fas fa-seedling"></i></div>
                            <h3 class="level-title">Level Medium (Fondasi)</h3>
                            <p>Pemula • 45-60 menit • Pola dasar</p>
                        </div>
                        <div class="level-card" onclick="showLevelDetail('hard')">
                            <div class="level-icon"><i class="fas fa-bolt"></i></div>
                            <h3 class="level-title">Tingkat Keras (Optimasi)</h3>
                            <p>Cutting • Drop Sets • Timer</p>
                        </div>
                        <div class="level-card" onclick="showLevelDetail('extreme')">
                            <div class="level-icon"><i class="fas fa-fire"></i></div>
                            <h3 class="level-title">Tingkat Otot (Ekstrem)</h3>
                            <p>Hipertrofi • Volume tinggi • Makro</p>
                        </div>
                    </div>
                </div>

                <!-- Slide 5: Progress Tracker -->
                <div class="slide">
                    <h2><i class="fas fa-chart-bar"></i> PROGRESS TRACKER</h2>
                    <p>Monitor perkembangan berat badan dan kekuatan Anda dengan grafik interaktif.</p>
                    <div class="progress-tracker">
                        <div class="input-group">
                            <label>Minggu</label>
                            <input type="number" id="weekInput" placeholder="1" min="1">
                        </div>
                        <div class="input-group">
                            <label>Berat Badan (kg)</label>
                            <input type="number" id="weightInput" placeholder="70" step="0.1">
                        </div>
                        <div class="input-group">
                            <label>1RM Bench Press (kg)</label>
                            <input type="number" id="benchInput" placeholder="80" step="0.1">
                        </div>
                        <div class="input-group">
                            <label>1RM Squat (kg)</label>
                            <input type="number" id="squatInput" placeholder="100" step="0.1">
                        </div>
                        <button class="btn" onclick="addProgressData()">Tambah Data</button>
                        <div class="chart-container" id="chartContainer">
                            <canvas id="progressChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <button class="nav-buttons prev" onclick="prevSlide()">
                <i class="fas fa-chevron-left"></i>
            </button>
            <button class="nav-buttons next" onclick="nextSlide()">
                <i class="fas fa-chevron-right"></i>
            </button>
        </div>

        <div class="dots-container" id="dots"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;
        let progressData = [];
        let progressChart = null;

        // Initialize slider
        function initSlider() {
            createDots();
            updateSlider();
        }

        function createDots() {
            const dotsContainer = document.getElementById('dots');
            dotsContainer.innerHTML = '';
            for (let i = 0; i < totalSlides; i++) {
                const dot = document.createElement('span');
                dot.classList.add('dot');
                if (i === 0) dot.classList.add('active');
                dot.onclick = () => goToSlide(i);
                dotsContainer.appendChild(dot);
            }
        }

        function updateSlider() {
            const slider = document.getElementById('slider');
            slider.style.transform = `translateX(-${currentSlide * 100}%)`;

            // Update dots
            document.querySelectorAll('.dot').forEach((dot, index) => {
                dot.classList.toggle('active', index === currentSlide);
            });
        }

        function goToSlide(n) {
            currentSlide = (n + totalSlides) % totalSlides;
            updateSlider();
        }

        function nextSlide() {
            goToSlide(currentSlide + 1);
        }

        function prevSlide() {
            goToSlide(currentSlide - 1);
        }

        // Diet Functions
        function showDietOptions() {
            document.getElementById('diet-options').style.display = 'block';
        }

        // Bodybuilding Level Details
        function showLevelDetail(level) {
            let title, description;
            switch(level) {
                case 'medium':
                    title = 'Level Medium (Fondasi)';
                    description = 'Target: Pemula. Fokus pola dasar, 45-60 menit. Praktis & disiplin.';
                    break;
                case 'hard':
                    title = 'Tingkat Keras (Optimasi)';
                    description = 'Target: Cutting/strength. Drop Sets, Supersets, HIIT + log latihan.';
                    break;
                case 'extreme':
                    title = 'Tingkat Otot (Ekstrem)';
                    description = 'Target: Hipertrofi. Volume tinggi, TUT panjang + kalkulator makro.';
                    break;
            }
            alert(`${title}\n\n${description}`);
        }

        // Progress Tracker
        function showProgressTracker() {
            goToSlide(4);
        }

        function showCustomDiet() {
            alert('Fitur Generator Menu akan menyarankan berdasarkan bahan yang tersedia (ayam, telur, dll)');
        }

        function addProgressData() {
            const week = parseInt(document.getElementById('weekInput').value);
            const weight = parseFloat(document.getElementById('weightInput').value);
            const bench = parseFloat(document.getElementById('benchInput').value);
            const squat = parseFloat(document.getElementById('squatInput').value);

            if (week && weight && bench && squat) {
                progressData.push({ week, weight, bench, squat });
                updateChart();
                clearInputs();
            } else {
